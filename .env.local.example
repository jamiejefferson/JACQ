# Supabase (create project at https://supabase.com)
# 1. Enable Google provider: Authentication > Providers > Google (add Client ID + Secret from Google Cloud Console)
# 2. Add redirect URL(s): Authentication > URL Configuration > Redirect URLs
#    Add the EXACT URL your app uses after login, e.g.:
#    http://localhost:3000/auth/callback
#    http://localhost:3007/auth/callback
#    (Use the port your dev server prints when you run npm run dev)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — needed for Telegram setup (saving bot token) and webhook.
# Get it: Supabase Dashboard → Project Settings → API → "service_role" (secret). Never expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Google API (same credentials configured in Supabase Google provider — needed for token refresh)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- Optional: Telegram (can also set up in-app via Settings → Integrations → Telegram → Set up) -----
# If you prefer env instead of pasting in the app, set:
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourBot_username
# TELEGRAM_BOT_TOKEN=your-token-from-BotFather

# ----- Optional: Web search (Tavily — https://tavily.com) -----
# Enables web_search tool so Jacq can look things up online. Free tier: 1000 searches/month.
TAVILY_API_KEY=

# ----- Optional: Proactivity cron (Vercel) -----
# Set in Vercel for the cron job that hits /api/proactive/run. Must match Authorization: Bearer <value>.
# CRON_SECRET=

# ----- Optional: for webhook when deployed -----
# Set your app’s public URL so the Telegram webhook can be registered when you save the token in the app.
# Local dev: leave blank (webhook won’t be set; use a tunnel like ngrok if you need it).
# Deployed: e.g. https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=
